rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function me() {
      return userDoc(request.auth.uid);
    }

    function isSuperAdmin() {
      return isSignedIn() && me().role == 'super_admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // True if the signed-in user may see/manage a task, mirroring
    // `isTaskVisibleToUser` on the client:
    // - super_admin sees/manages every task.
    // - a task with visibleToAllGroups == true is visible to any
    //   signed-in user.
    // - otherwise a normal user may only access tasks whose groupId
    //   matches their own groupId.
    // - tasks created before this feature have no groupId field at all;
    //   `.get('groupId', null)` defaults those to null, so (per the rule
    //   above) only super_admin can access them until they're assigned a
    //   group.
    function canAccessTask(task) {
      return isSuperAdmin()
        || (task.get('groupId', null) != null
            && (task.get('visibleToAllGroups', false) == true
                || task.get('groupId', null) == me().groupId));
    }

    // Sprint 7.4.9B — only the task's current assignedUserId or a
    // super_admin may directly change the reminder. Mirrors the rule
    // enforced client-side in AddEditTaskPage (Encargado edita su propio
    // recordatorio / Administrador edita cualquiera).
    function canEditReminder() {
      return isSuperAdmin()
        || request.auth.uid == resource.data.get('assignedUserId', null);
    }

    // True when this write leaves reminderTime/reminderSent exactly as they
    // were — any user who already passes canAccessTask() may still edit
    // every other field freely (complete, soft-delete, edit other fields).
    function reminderUnchanged() {
      return request.resource.data.get('reminderTime', null) == resource.data.get('reminderTime', null)
        && request.resource.data.get('reminderSent', false) == resource.data.get('reminderSent', false);
    }

    // True when date/hour is changing — a reschedule, which legitimately
    // recalculates/clears the reminder as a side effect and is intentionally
    // not gated by canEditReminder() (reschedule permissions are unchanged
    // by this sprint).
    function taskTimeChanged() {
      return request.resource.data.get('date', null) != resource.data.get('date', null)
        || request.resource.data.get('hour', null) != resource.data.get('hour', null);
    }

    // -----------------------------------------------------------------
    // users
    // -----------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      // Accounts are provisioned from the admin panel only.
      allow create: if isSuperAdmin();
      // Admins can edit any field (role, group, etc). Regular users may
      // only update the fields the app touches on their own behalf,
      // including their own visual preferences (themeMode/accentColor).
      allow update: if isSuperAdmin()
        || (isOwner(userId)
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['fcmTokens', 'lastLogin', 'streakDays', 'maxStreakDays', 'name', 'themeMode', 'accentColor',  'photoUrl', 'pushNotificationMode']));
      allow delete: if isSuperAdmin();
    }

    // -----------------------------------------------------------------
    // tasks
    // -----------------------------------------------------------------
    match /tasks/{taskId} {
      // Single-document reads: `resource.data` is concrete here, so the
      // get()-based canAccessTask() check evaluates per document as expected.
      allow get: if isSignedIn() && canAccessTask(resource.data);
      // Collection queries (watchTasksForDate/watchTasksInRange): rules
      // aren't filters. canAccessTask() depends on resource.data fields
      // that vary per doc and aren't constrained by the date/hour query
      // filters, so for any role other than super_admin (the only branch
      // that's constant w.r.t. resource.data) Firestore can't prove the
      // rule holds for the whole result set and rejects the ENTIRE query
      // with permission-denied. So list is open to any signed-in user;
      // privacy is enforced client-side via isTaskVisibleToUser
      // (lib/core/utils/task_visibility.dart), same as groups/taskTypes/etc.
      allow list: if isSignedIn();
      allow create: if isSignedIn() && canAccessTask(request.resource.data);
      // Sprint 7.4.9B: a direct change to reminderTime/reminderSent (not a
      // side effect of rescheduling) additionally requires canEditReminder()
      // — the task's current assignedUserId or a super_admin.
      allow update: if isSignedIn()
        && canAccessTask(resource.data)
        && canAccessTask(request.resource.data)
        && (reminderUnchanged() || taskTimeChanged() || canEditReminder());
      // Permanent delete is restricted to super_admin.
      // Soft delete uses update() above and is available to any signed-in user
      // who can access the task.
      allow delete: if isSuperAdmin();
    }

    // -----------------------------------------------------------------
    // Catalog collections: readable by any signed-in user (needed to
    // resolve names/colors throughout the app), editable only by admins.
    // -----------------------------------------------------------------
    match /groups/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /taskTypes/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /statuses/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /availableHours/{id} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // -----------------------------------------------------------------
    // systemConfig — global system configuration (Sprint 22)
    // Readable by any signed-in user (all screens need the current mode);
    // writable only by super_admin.
    // -----------------------------------------------------------------
    match /systemConfig/{doc} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // -----------------------------------------------------------------
    // notifications (Sprint 7.4 — in-app notification center)
    // -----------------------------------------------------------------
    match /notifications/{id} {
      // Documents are written only by Cloud Functions via the
      // firebase-admin SDK, which bypasses Security Rules entirely — so
      // clients can never fabricate a notification for themselves or
      // anyone else.
      allow create: if false;
      // Single-document reads: resource.data is concrete here, so this
      // evaluates per document as expected.
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Collection queries (watchNotifications/unreadCount): same rationale
      // as tasks' `list` rule above — rules can't constrain per-doc fields
      // across an arbitrary query result set, so list is open to any
      // signed-in user; privacy is enforced by the repository always
      // querying `where('userId', isEqualTo: <own uid>)`.
      allow list: if isSignedIn();
      // markAsRead/markAllAsRead: the owner may only flip isRead.
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      // Sprint 7.4.7 Objetivo E/F: a user may delete their own notifications
      // (single delete or "vaciar historial") — never anyone else's, not
      // even super_admin, since this isn't an admin-moderation feature.
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
